#!/usr/bin/env zunit
#
# -*- mode: zsh; sh-indentation: 2; indent-tabs-mode: nil; sh-basic-offset: 2; -*-
# vim: ft=zsh sw=2 ts=2 et
#

@setup {
  load setup
  load helpers
  setup
}

@teardown {
  load setup
  teardown
}

@test 'startup failure returns without exiting the shell when eza is missing' {
  run_zsh_eza_shell '
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    rc=$?
    print -- "rc=${rc}"
    print -- "after-source"
  ' "${ZSH_EZA_TEST_EMPTY_PATH}"

  assert $state equals 0
  assert "$output" contains 'Please install eza before using this plugin.'
  assert "$output" contains 'Error loading zsh-eza plugin, exit code: 1'
  assert "$output" contains 'rc=1'
  assert "$output" contains 'after-source'
}

@test 'scalar custom params are split into separate eza arguments' {
  make_fake_eza

  run_zsh_eza_shell '
    eza_user_params="--git --icons"
    eza_extra_params="--classify --tree"
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    eval "${aliases[ls]}"
  '

  assert $state equals 0
  assert "$output" contains 'fake-eza [--git] [--icons] [--classify] [--tree]'
}

@test 'unload restores aliases and removes the AUTOCD hook' {
  make_fake_eza

  run_zsh_eza_shell '
    alias ls="ls --color=auto"
    AUTOCD=1
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    print -- "loaded=${aliases[ls]}"

    if [[ ${chpwd_functions[(r)zsh-eza-auto-list]} == zsh-eza-auto-list ]]; then
      print -- "hook=present"
    fi

    zsh-eza_plugin_unload
    print -- "restored=${aliases[ls]}"

    if (( ${+functions[zsh-eza-auto-list]} )); then
      print -- "hook-function=present"
    else
      print -- "hook-function=removed"
    fi

    if [[ ${chpwd_functions[(r)zsh-eza-auto-list]} == zsh-eza-auto-list ]]; then
      print -- "hook-entry=present"
    else
      print -- "hook-entry=removed"
    fi
  '

  assert $state equals 0
  assert "$output" contains 'loaded=eza ${(@)eza_params}'
  assert "$output" contains 'hook=present'
  assert "$output" contains 'restored=ls --color=auto'
  assert "$output" contains 'hook-function=removed'
  assert "$output" contains 'hook-entry=removed'
}

@test 'default eza_params contains all six expected flags' {
  make_fake_eza

  run_zsh_eza_shell '
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    print -- "${eza_params[@]}"
  '

  assert $state equals 0
  assert "$output" contains '--git'
  assert "$output" contains '--icons'
  assert "$output" contains '--group'
  assert "$output" contains '--group-directories-first'
  assert "$output" contains '--time-style=long-iso'
  assert "$output" contains '--color-scale=all'
}

@test 'all eight ls-style aliases are defined after load' {
  make_fake_eza

  run_zsh_eza_shell '
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    for a in ls l ll llm la lx lt tree; do
      if (( ${+aliases[$a]} )); then
        print -- "alias:${a}=present"
      else
        print -- "alias:${a}=missing"
      fi
    done
  '

  assert $state equals 0
  assert "$output" contains 'alias:ls=present'
  assert "$output" contains 'alias:l=present'
  assert "$output" contains 'alias:ll=present'
  assert "$output" contains 'alias:llm=present'
  assert "$output" contains 'alias:la=present'
  assert "$output" contains 'alias:lx=present'
  assert "$output" contains 'alias:lt=present'
  assert "$output" contains 'alias:tree=present'
}

@test 'ls alias invokes eza with all default params' {
  make_fake_eza

  run_zsh_eza_shell '
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    eval "${aliases[ls]}"
  '

  assert $state equals 0
  assert "$output" contains 'fake-eza'
  assert "$output" contains '[--git]'
  assert "$output" contains '[--icons]'
  assert "$output" contains '[--group-directories-first]'
  assert "$output" contains '[--time-style=long-iso]'
  assert "$output" contains '[--color-scale=all]'
}

@test 'll alias prepends --all --header --long before eza_params' {
  make_fake_eza

  run_zsh_eza_shell '
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    eval "${aliases[ll]}"
  '

  assert $state equals 0
  assert "$output" contains '[--all]'
  assert "$output" contains '[--header]'
  assert "$output" contains '[--long]'
  assert "$output" contains '[--git]'
}

@test 'eza_user_params replaces default params entirely' {
  make_fake_eza

  run_zsh_eza_shell '
    eza_user_params="--only-this"
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    if [[ "${(j: :)eza_params}" == "--only-this" ]]; then
      print -- "params=replaced"
    else
      print -- "params=not-replaced:${(j: :)eza_params}"
    fi
    eval "${aliases[ls]}"
  '

  assert $state equals 0
  assert "$output" contains 'params=replaced'
  assert "$output" contains 'fake-eza [--only-this]'
}

@test 'eza_extra_params appends to default params without replacing them' {
  make_fake_eza

  run_zsh_eza_shell '
    eza_extra_params="--extra-flag"
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    if [[ "${eza_params[-1]}" == "--extra-flag" ]]; then
      print -- "extra=appended"
    else
      print -- "extra=not-appended:last=${eza_params[-1]}"
    fi
    if [[ "${eza_params[1]}" == "--git" ]]; then
      print -- "defaults=preserved"
    else
      print -- "defaults=missing:first=${eza_params[1]}"
    fi
  '

  assert $state equals 0
  assert "$output" contains 'extra=appended'
  assert "$output" contains 'defaults=preserved'
}

@test 'AUTOCD=1 registers zsh-eza-auto-list in chpwd_functions' {
  make_fake_eza

  run_zsh_eza_shell '
    AUTOCD=1
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    if [[ ${chpwd_functions[(r)zsh-eza-auto-list]} == zsh-eza-auto-list ]]; then
      print -- "hook=registered"
    else
      print -- "hook=absent"
    fi
  '

  assert $state equals 0
  assert "$output" contains 'hook=registered'
}

@test 'AUTOCD=0 does not register chpwd hook' {
  make_fake_eza

  run_zsh_eza_shell '
    AUTOCD=0
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    if [[ ${chpwd_functions[(r)zsh-eza-auto-list]} == zsh-eza-auto-list ]]; then
      print -- "hook=registered"
    else
      print -- "hook=absent"
    fi
  '

  assert $state equals 0
  assert "$output" contains 'hook=absent'
}

@test 'zsh-eza-auto-list hook invokes eza with default params' {
  make_fake_eza

  run_zsh_eza_shell '
    AUTOCD=1
    source "${ZSH_EZA_REPO}/zsh-eza.plugin.zsh"
    zsh-eza-auto-list
  '

  assert $state equals 0
  assert "$output" contains 'fake-eza'
  assert "$output" contains '[--git]'
  assert "$output" contains '[--icons]'
}
